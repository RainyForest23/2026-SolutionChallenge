###############################################
# Project Configuration (Example)
# Copy this file to .env and fill values locally.
# DO NOT commit real secrets.
###############################################

# ===== GCP =====
PROJECT_ID=sc-soundsight
GOOGLE_CLOUD_PROJECT=sc-soundsight
REGION=us-central1

# ===== Django =====
DJANGO_SECRET_KEY=replace-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== Gemini =====
GEMINI_API_KEY=

# ===== Firebase =====
FIREBASE_PROJECT_ID=sc-soundsight
FIREBASE_STORAGE_BUCKET=sc-soundsight.firebasestorage.app
# Local development only. Do not set this on Cloud Run.
GOOGLE_APPLICATION_CREDENTIALS=./secret/serviceAccountKey.json
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=sc-soundsight.firebaseapp.com

# ===== Cloud Run =====
SERVICE_NAME=soundsight
# Cloud Run uses the attached service account via ADC.
# Leave GOOGLE_APPLICATION_CREDENTIALS unset in Cloud Run.

# ===== Artifact Registry =====
REPO_NAME=soundsight
IMAGE_TAG=v1
