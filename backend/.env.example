###############################################
# Project Configuration (Example)
# Copy this file to .env and fill values locally.
# DO NOT commit real secrets.
###############################################

# ===== GCP =====
PROJECT_ID=sc-soundsight
GOOGLE_CLOUD_PROJECT=sc-soundsight
REGION=us-central1

# ===== Django =====
DJANGO_SECRET_KEY=replace-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
# Optional for Expo web / browser-based demo frontend
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ===== Gemini =====
GEMINI_API_KEY=

# ===== Firebase =====
FIREBASE_PROJECT_ID=sc-soundsight
FIREBASE_STORAGE_BUCKET=sc-soundsight.firebasestorage.app
# Local development only. Do not set this on Cloud Run.
GOOGLE_APPLICATION_CREDENTIALS=./secret/serviceAccountKey.json
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=sc-soundsight.firebaseapp.com

# ===== Cloud Run =====
SERVICE_NAME=soundsight
# Cloud Run uses the attached service account via ADC.
# Leave GOOGLE_APPLICATION_CREDENTIALS unset in Cloud Run.
# Single-service demo mode without a separate Celery worker/broker.
CELERY_TASK_ALWAYS_EAGER=true
# Optional yt-dlp overrides for YouTube anti-bot workarounds.
# Example: youtube:player_client=default,mweb
YTDLP_EXTRACTOR_ARGS=
# Example secret mount path on Cloud Run: /secrets/youtube-cookies.txt
YTDLP_COOKIES_PATH=
# When you add a real broker later, disable eager mode and provide the broker URLs.
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===== Artifact Registry =====
REPO_NAME=soundsight
IMAGE_TAG=v1
